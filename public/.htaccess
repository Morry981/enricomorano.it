<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

RewriteEngine On

# Force www + HTTPS
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^enricomorano\.it$ [NC]
RewriteRule ^(.*)$ https://www.enricomorano.it/$1 [L,R=301]

# Strip trailing slash (eccetto root) per canonical URL pulito
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^ %1 [R=301,L]

# Markdown content negotiation: agent con Accept: text/markdown riceve il .md
# corrispondente generato al build dall'integration markdown-generator.
RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /index.md [L,T=text/markdown,E=MD_HIT:1]

RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
RewriteCond %{REQUEST_URI} !\.(md|html?|xml|txt|json|js|css|png|jpe?g|webp|svg|ico|woff2?)$
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.md -f
RewriteRule ^(.+)$ /$1.md [L,T=text/markdown,E=MD_HIT:1]

<IfModule mod_setenvif.c>
    # Cattura il path della request originale (no query string) per Link canonical
    SetEnvIf Request_URI "^([^?]*?)(\.md)?$" CANONICAL_PATH=$1
</IfModule>

<IfModule mod_headers.c>
    # Content-Type override per i .md serviti via negotiation (alcuni server li sniffano text/plain)
    <FilesMatch "\.md$">
        Header set Content-Type "text/markdown; charset=utf-8"
    </FilesMatch>

    # Link rel="canonical" HTTP header dinamico path-aware (RFC 8288 / 6596).
    # Punta sempre alla versione canonical HTML anche quando si serve il .md.
    Header set Link "<https://www.enricomorano.it%{CANONICAL_PATH}e>; rel=\"canonical\""

    # Vary: Accept su risposte negoziabili (HTML default vs MD via Accept)
    Header append Vary "Accept"
</IfModule>