PUBLIC_MIXPANEL_TOKEN=
PUBLIC_WHATSAPP_NUMBER=
# URL profilo Google Business (opzionale: se vuoto, il blocco GMB in /contatti non compare)
PUBLIC_GMB_URL=

# SMTP per il form /contatti (server-side, NON committare i valori reali)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=web@enricomorano.it
SMTP_PASS=
# destinatario notifiche form (default: web@enricomorano.it) e mittente (default: SMTP_USER)
CONTACT_TO=web@enricomorano.it
CONTACT_FROM=