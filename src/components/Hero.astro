---
interface Label {
    text: string;
    bg: string;
    deg: number;
    delay: number;
    href: string;
}

const labelsEnrico: Label[] = [
    { text: 'e-commerce',  bg: '#a8e6cf', deg: -4, delay: 0,   href: '/skills#ecommerce'  },
    { text: 'SEO tecnica', bg: '#b8d4f8', deg:  4, delay: 180, href: '/skills#seo'         },
    { text: 'consulenza',  bg: '#ffcba4', deg: -6, delay: 330, href: '/skills#strategy'    },
    { text: 'Vue.js',      bg: '#c3e8c3', deg:  3, delay: 490, href: '/skills#webdev'      },
    { text: 'performance', bg: '#fde68a', deg: -3, delay: 640, href: '/skills#seo'         },
];

const labelsMorano: Label[] = [
    { text: 'automazione',        bg: '#c9c5e0', deg:  3, delay: 110, href: '/skills#automation' },
    { text: 'PrestaShop',         bg: '#ffd4a8', deg: -4, delay: 260, href: '/skills#ecommerce'  },
    { text: 'strategia digitale', bg: '#f4b8c1', deg:  5, delay: 400, href: '/skills#strategy'   },
    { text: 'problem solver',     bg: '#b8e8d4', deg:  7, delay: 540, href: '/skills#proactive'  },
    { text: 'infrastrutture',     bg: '#e8d4b8', deg: -3, delay: 680, href: '/skills#webdev'     },
];

function ls(l: Label): string {
    return `--deg: ${l.deg}deg; --delay: ${l.delay}ms; --label-bg: ${l.bg}; --label-fg: var(--bg);`;
}
import { Image } from 'astro:assets';
import fotoProfilo from '../assets/images/foto-profilo.jpg';
import logoMorry from '../assets/images/logo-morry98.png';
---

<section
    id="hero"
    class="relative h-[100svh] min-h-[560px] flex flex-col items-center justify-center overflow-hidden"
>
    <Image
        src={logoMorry}
        alt=""
        aria-hidden="true"
        widths={[200, 400]}
        class="fixed bottom-[-15%] right-[-4%] h-[60vh] w-auto opacity-[0.02] pointer-events-none select-none object-contain"
    />

    <h1
        class="hero-row flex flex-row items-stretch justify-center gap-4 w-full m-0 z-[1]"
        aria-label="Enrico Morano"
    >
        <div
            id="wrap-enrico"
            class="flex-1 relative flex items-center justify-end overflow-visible min-w-0"
        >
            <span class="hero-word font-black text-light uppercase whitespace-nowrap select-none pointer-events-none block">
                ENRICO
            </span>
            {labelsEnrico.map((l, i) => (
                <a
                    href={l.href}
                    class="hero-label absolute text-[13px] sm:text-sm lg:text-base font-medium whitespace-nowrap z-30 px-[14px] sm:px-4 sm:py-[6px] lg:px-5 lg:py-2 rounded-full corner-squircle"
                    data-pos={i}
                    style={ls(l)}
                >
                    {l.text}
                </a>
            ))}
        </div>

        <div class="photo-frame shrink-0 self-center overflow-hidden border-[5px] border-accent shadow-[0_20px_56px_rgba(0,0,0,0.35)] rounded-2xl corner-squircle">
            <Image
                src={fotoProfilo}
                alt="Foto di Enrico Morano"
                width={440}
                height={587}
                quality={80}
                class="block w-full h-full object-cover object-top"
                loading="eager"
            />
        </div>

        <div
            id="wrap-morano"
            class="flex-1 relative flex items-center justify-start overflow-visible min-w-0"
        >
            <span class="hero-word font-black text-light uppercase whitespace-nowrap select-none pointer-events-none block">
                MORANO
            </span>
            {labelsMorano.map((l, i) => (
                <a
                    href={l.href}
                    class="hero-label absolute text-[13px] sm:text-sm lg:text-base font-medium whitespace-nowrap z-30 px-[14px] sm:px-4 sm:py-[6px] lg:px-5 lg:py-2 rounded-full corner-squircle"
                    data-pos={i}
                    style={ls(l)}
                >
                    {l.text}
                </a>
            ))}
        </div>
    </h1>

    <p class="hero-tagline absolute bottom-[9%] left-1/2 -translate-x-1/2 w-[88%] max-w-[520px] text-center text-secondary leading-[1.55] z-30 text-balance">
        Elimino l'attrito tecnologico tra la tua azienda e i tuoi risultati.
    </p>

    <a href="#competenze" class="scroll-hint absolute bottom-6 left-1/2 -translate-x-1/2 text-secondary z-30" aria-label="Vai a Come posso aiutare">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </a>
</section>

<style>
    .hero-row { font: inherit; }

    .hero-word {
        font-family: var(--font-retro);
        line-height: 1;
        transform: scaleY(2.5);
        transform-origin: center center;
    }

    .photo-frame {
        width:  clamp(160px, 26vh, 310px);
        height: clamp(213px, 35vh, 413px);
    }

    .hero-label {
        background-color: var(--label-bg);
        color:            var(--label-fg);
        opacity: 0;
        rotate:    var(--deg);
        translate: 0 10px;
        scale: 1;
        text-decoration: none;
        animation: labelIn 0.45s ease forwards var(--delay);
        transition: scale 0.25s ease, translate 0.25s ease, rotate 0.25s ease, box-shadow 0.25s ease;
    }

    @media (prefers-reduced-motion: no-preference) {
        @keyframes labelIn {
            to { opacity: 1; translate: 0 0; }
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-label {
            opacity: 1;
            translate: 0 0;
            animation: none;
        }
        .scroll-hint {
            animation: none;
        }
    }

    .hero-label:hover,
    .hero-label:focus-visible {
        scale:     1.1;
        translate: 0 -4px;
        rotate:    0deg;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.22);
        z-index: 40;
        outline: 2px solid var(--label-bg);
        outline-offset: 2px;
    }

    .hero-tagline {
        font-size: clamp(14px, 1.6vw, 18px);
    }

    @media (prefers-reduced-motion: no-preference) {
        .scroll-hint {
            animation: scrollBounce 2s ease-in-out infinite;
        }

        @keyframes scrollBounce {
            0%, 100% { transform: translateX(-50%) translateY(0);   }
            50%       { transform: translateX(-50%) translateY(6px); }
        }
    }

    @media (min-width: 1024px) {
        .hero-word {
            /*
             * Clamp calcolato su MORANO (parola più larga con M e A):
             *   wrap = (100vw - foto_26vh - gap_2rem) / 2
             *   char_ratio fantasy uppercase ≈ 0.85 × 6 chars = 5.1
             *   font_size = wrap / 5.1  →  divisore totale = 9.8 (+~4%)
             */
            font-size: clamp(44px, calc((100vw - 26vh - 2rem) / 9.8), 240px);
            transform: scaleY(3);
            transform-origin: center center;
        }

        #wrap-enrico .hero-word { letter-spacing: 0.12em; }
        #wrap-morano .hero-word { letter-spacing: 0.04em; }

        #wrap-enrico .hero-label[data-pos="0"] { top:  5%;  left:  5%; }
        #wrap-enrico .hero-label[data-pos="1"] { top: 40%;  left: 26%; }
        #wrap-enrico .hero-label[data-pos="2"] { top: 70%;  left: 50%; }
        #wrap-enrico .hero-label[data-pos="3"] { top: 20%;  left: 68%; }
        #wrap-enrico .hero-label[data-pos="4"] { top: 82%;  left: 84%; }

        #wrap-morano .hero-label[data-pos="0"] { top:  5%;  right:  5%; }
        #wrap-morano .hero-label[data-pos="1"] { top: 45%;  right: 22%; }
        #wrap-morano .hero-label[data-pos="2"] { top: 22%;  right: 42%; }
        #wrap-morano .hero-label[data-pos="3"] { top: 68%;  right: 60%; }
        #wrap-morano .hero-label[data-pos="4"] { top: 38%;  right: 76%; }
    }

    @media (min-width: 640px) and (max-width: 1023px) {
        .hero-word {
            writing-mode: vertical-lr;
            text-orientation: upright;
            font-size: clamp(42px, 7vh, 92px);
            letter-spacing: 0.04em;
            transform: none;
        }

        #wrap-enrico,
        #wrap-morano {
            min-width: 200px;
        }

        .photo-frame {
            width:  clamp(130px, 22vh, 240px);
            height: clamp(173px, 29vh, 320px);
        }

        #wrap-enrico .hero-label[data-pos="0"] { top:  5%;  left:  5%; }
        #wrap-enrico .hero-label[data-pos="1"] { top: 42%;  left: 24%; }
        #wrap-enrico .hero-label[data-pos="2"] { top: 68%;  left: 46%; }
        #wrap-enrico .hero-label[data-pos="3"] { top: 22%;  left: 64%; }
        #wrap-enrico .hero-label[data-pos="4"] { top: 82%;  left: 80%; }

        #wrap-morano .hero-label[data-pos="0"] { top:  5%;  right:  5%; }
        #wrap-morano .hero-label[data-pos="1"] { top: 48%;  right: 20%; }
        #wrap-morano .hero-label[data-pos="2"] { top: 22%;  right: 38%; }
        #wrap-morano .hero-label[data-pos="3"] { top: 70%;  right: 56%; }
        #wrap-morano .hero-label[data-pos="4"] { top: 38%;  right: 72%; }
    }

    @media (max-width: 639px) {
        .hero-row {
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        #wrap-enrico,
        #wrap-morano {
            width: 100%;
            min-height: 80px;
            justify-content: center;
        }

        .hero-word {
            font-size: 20vw;
            line-height: 0.9;
            text-align: center;
        }

        .photo-frame {
            width:  clamp(140px, 22vh, 220px);
            height: clamp(187px, 30vh, 293px);
        }

        #wrap-enrico .hero-label[data-pos="0"] { top: 8px;    left: 0.75rem;  }
        #wrap-enrico .hero-label[data-pos="1"] { bottom: 8px; right: 0.75rem; }
        #wrap-enrico .hero-label[data-pos="2"] { display: none; }
        #wrap-enrico .hero-label[data-pos="3"] { display: none; }
        #wrap-enrico .hero-label[data-pos="4"] { display: none; }

        #wrap-morano .hero-label[data-pos="0"] { top: 8px;    right: 0.75rem; }
        #wrap-morano .hero-label[data-pos="1"] { bottom: 8px; left: 0.75rem;  }
        #wrap-morano .hero-label[data-pos="2"] { display: none; }
        #wrap-morano .hero-label[data-pos="3"] { display: none; }
        #wrap-morano .hero-label[data-pos="4"] { display: none; }
    }
</style>
