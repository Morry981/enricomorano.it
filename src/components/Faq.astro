---
interface FaqItem {
    question: string;
    answer: string;
}
interface Props {
    items: FaqItem[];
    title?: string;
}
const { items, title = 'Domande frequenti' } = Astro.props;

const schema = {
    '@context': 'https://schema.org/',
    '@type': 'FAQPage',
    mainEntity: items.map((i) => ({
        '@type': 'Question',
        name: i.question,
        acceptedAnswer: { '@type': 'Answer', text: i.answer },
    })),
};
---

<section class="faq-block">
    <h2 id="faq">❓ {title}</h2>
    <div class="faq-list">
        {
            items.map((i) => (
                <details>
                    <summary>{i.question}</summary>
                    <div class="a">{i.answer}</div>
                </details>
            ))
        }
    </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        margin-top: 1rem;
    }
    details {
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--surface);
        overflow: hidden;
    }
    summary {
        cursor: pointer;
        list-style: none;
        padding: 0.9rem 1.05rem;
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    summary::-webkit-details-marker {
        display: none;
    }
    summary::after {
        content: '+';
        color: var(--color-accent);
        font-size: 1.3rem;
        line-height: 1;
        flex: 0 0 auto;
    }
    details[open] summary::after {
        content: '\2212';
    }
    .a {
        padding: 0 1.05rem 1rem;
        color: var(--fg-secondary);
    }
</style>
