---
export interface FaqItem {
    question: string;
    answer: string;
}

interface Props {
    faqs: FaqItem[];
    title?: string;
}

const { faqs, title = 'Domande frequenti' } = Astro.props;

const faqSchema = {
    '@context': 'https://schema.org/',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
            '@type': 'Answer',
            text: faq.answer,
        },
    })),
};
---

<section class="max-w-6xl mx-auto px-6 pt-12 pb-4">
    <h2 class="text-2xl font-bold mb-4 text-secondary">{title}</h2>
    <div class="space-y-2">
        {faqs.map((faq) => (
            <details class="group border border-(--border) rounded-xl overflow-hidden">
                <summary class="flex items-center justify-between gap-4 px-5 py-3 cursor-pointer text-light font-medium hover:bg-(--surface) transition-colors select-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:-outline-offset-2 rounded-xl">
                    <span class="text-sm">{faq.question}</span>
                    <svg
                        class="w-4 h-4 shrink-0 text-accent transition-transform duration-300 group-open:rotate-180"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                    >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </summary>
                <div class="px-5 pt-4 pb-4 text-sm text-light/60 text-balance">
                    {faq.answer}
                </div>
            </details>
        ))}
    </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
