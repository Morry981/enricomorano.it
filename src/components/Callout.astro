---
interface Props {
    type?: 'note' | 'warn' | 'key';
    title?: string;
}
const { type = 'note', title } = Astro.props;
const icon = { note: '●', warn: '▲', key: '◆' }[type];
const fallback = { note: 'Nota', warn: 'Attenzione', key: 'In sintesi' }[type];
---

<aside class={`callout ${type}`}>
    <span class="ic" aria-hidden="true">{icon}</span>
    <div class="bd">
        <b>{title ?? fallback}</b>
        <slot />
    </div>
</aside>

<style>
    .callout {
        display: flex;
        gap: 0.75rem;
        margin: 1.6rem 0;
        padding: 1rem 1.1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-left-width: 3px;
        border-radius: 12px;
    }
    .ic {
        font-size: 1.1rem;
        line-height: 1.6;
    }
    .bd {
        font-size: 0.98rem;
    }
    .bd b {
        display: block;
        margin-bottom: 0.15rem;
    }
    .callout.note {
        border-left-color: var(--color-primary);
    }
    .callout.warn {
        border-left-color: #f39c12;
    }
    .callout.key {
        border-left-color: var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 8%, var(--surface));
    }
    .bd :global(p) {
        margin: 0;
    }
    .bd :global(p + p) {
        margin-top: 0.5rem;
    }
</style>
