<blockquote class="pullquote corner-squircle"><slot /></blockquote>

<style>
    .pullquote {
        margin: 2rem 0;
        padding: 1.1rem 1.3rem;
        border-left: 4px solid var(--color-accent);
        border-radius: 14px;
        background: color-mix(in srgb, var(--color-accent) 8%, var(--surface));
        font-size: 1.4rem;
        line-height: 1.4;
        font-weight: 600;
        font-style: normal;
        color: var(--fg);
        text-wrap: balance;
    }
    .pullquote :global(em),
    .pullquote :global(strong) {
        color: var(--color-accent);
        font-style: normal;
    }
</style>
