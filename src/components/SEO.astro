---
import { personSchema, professionalServiceSchema, websiteSchema, breadcrumbSchema } from '../data/schemas';

interface Props {
    title: string;
    description: string;
    image?: string;
    type?: 'website' | 'article';
    breadcrumbs?: { name: string; url: string }[];
}

const {
    title,
    description,
    image = '/og-image.png',
    type = 'website',
    breadcrumbs,
} = Astro.props;

const siteUrl = (Astro.site ?? 'https://www.enricomorano.it').toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const fullTitle = title.includes('Enrico Morano') ? title : `${title} | Enrico Morano`;
const ogImageURL = new URL(image, siteUrl).toString();

const breadcrumbData = breadcrumbs && breadcrumbs.length > 0
    ? breadcrumbSchema(siteUrl, breadcrumbs)
    : null;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />
<meta name="author" content="Enrico Morano" />

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:locale" content="it_IT" />
<meta property="og:site_name" content="Enrico Morano" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={fullTitle} />

<script type="application/ld+json" set:html={JSON.stringify(personSchema(siteUrl))} />
<script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema(siteUrl))} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema(siteUrl))} />
{breadcrumbData && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
)}
