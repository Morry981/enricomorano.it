---
import { Image } from 'astro:assets';
import logoMorry from '../assets/images/logo-morry98.png';
import ThemeToggle from './ThemeToggle.vue';

const currentPath = Astro.url.pathname;

const links = [
    { href: '/',          label: 'Home' },
    { href: '/progetti',    label: 'Progetti' },
    { href: '/competenze', label: 'Competenze' },
    { href: '/chi-sono',   label: 'Chi Sono' },
];
---

<header class="fixed top-4 z-50 px-4 md:px-8 w-full">
    <nav
        aria-label="Navigazione principale"
        class="max-w-6xl mx-auto p-4 bg-dark/70 backdrop-blur-lg rounded-2xl corner-squircle border border-[var(--border)] flex items-center justify-between"
    >
        <a href="/" aria-label="Home - Enrico Morano" class="transition-opacity hover:opacity-70">
            <Image src={logoMorry} alt="Logo Enrico Morano" title="Enrico Morano - Home" width={32} height={32} loading="eager" fetchpriority="high" decoding="async" quality={80} class="h-8 w-8 object-contain rounded corner-squircle" />
        </a>

        <div class="hidden md:flex items-center gap-6">
            <ul class="flex space-x-6" role="list">
                {links.map(({ href, label }) => {
                    const isActive = href === '/'
                        ? currentPath === '/'
                        : currentPath.startsWith(href);
                    return (
                        <li>
                            <a
                                href={href}
                                class={`nav-link focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2${isActive ? ' text-accent' : ''}`}
                                aria-current={isActive ? 'page' : undefined}
                            >
                                {label}
                            </a>
                        </li>
                    );
                })}
            </ul>
            <ThemeToggle client:load />
        </div>

        <div class="flex md:hidden items-center gap-2">
            <ThemeToggle client:load />
            <button
                id="nav-toggle"
                aria-controls="mobile-menu"
                aria-expanded="false"
                aria-label="Apri menu"
                class="flex flex-col gap-1.5 p-3 min-w-[48px] min-h-[48px] items-center justify-center rounded-lg hover:bg-[var(--surface)] transition-colors"
            >
                <span class="block w-5 h-0.5 bg-light transition-all duration-300" id="bar1" aria-hidden="true"></span>
                <span class="block w-5 h-0.5 bg-light transition-all duration-300" id="bar2" aria-hidden="true"></span>
                <span class="block w-5 h-0.5 bg-light transition-all duration-300" id="bar3" aria-hidden="true"></span>
            </button>
        </div>
    </nav>

    <div
        id="mobile-menu"
        class="md:hidden hidden mt-2 max-w-6xl mx-auto bg-dark/90 backdrop-blur-lg rounded-2xl corner-squircle border border-[var(--border)] overflow-hidden"
        aria-hidden="true"
    >
        <ul class="flex flex-col p-4 gap-1" role="list">
            {links.map(({ href, label }) => {
                const isActive = href === '/'
                    ? currentPath === '/'
                    : currentPath.startsWith(href);
                return (
                    <li>
                        <a
                            href={href}
                            class={`block px-4 py-3 rounded-lg transition-colors hover:bg-[var(--surface)] font-medium${isActive ? ' text-accent bg-accent/10' : ' text-light'}`}
                            aria-current={isActive ? 'page' : undefined}
                        >
                            {label}
                        </a>
                    </li>
                );
            })}
        </ul>
    </div>
</header>

<script>
    function initNav() {
        const toggle = document.getElementById('nav-toggle');
        const menu = document.getElementById('mobile-menu');
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');

        toggle?.addEventListener('click', () => {
            const isOpen = menu?.classList.toggle('hidden') === false;
            toggle.setAttribute('aria-expanded', String(isOpen));
            toggle.setAttribute('aria-label', isOpen ? 'Chiudi menu' : 'Apri menu');
            menu?.setAttribute('aria-hidden', String(!isOpen));

            if (isOpen) {
                bar1?.classList.add('rotate-45', 'translate-y-2');
                bar2?.classList.add('opacity-0');
                bar3?.classList.add('-rotate-45', '-translate-y-2');
            } else {
                bar1?.classList.remove('rotate-45', 'translate-y-2');
                bar2?.classList.remove('opacity-0');
                bar3?.classList.remove('-rotate-45', '-translate-y-2');
            }
        });

        document.addEventListener('click', (e) => {
            if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
                menu?.classList.add('hidden');
                menu?.setAttribute('aria-hidden', 'true');
                toggle?.setAttribute('aria-expanded', 'false');
                toggle?.setAttribute('aria-label', 'Apri menu');
                bar1?.classList.remove('rotate-45', 'translate-y-2');
                bar2?.classList.remove('opacity-0');
                bar3?.classList.remove('-rotate-45', '-translate-y-2');
            }
        });
    }

    document.addEventListener('astro:page-load', initNav);
</script>
