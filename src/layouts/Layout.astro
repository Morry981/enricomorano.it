---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SEO from '../components/SEO.astro';
import Cursor from '../components/Cursor.vue';
import Footer from '../components/Footer.vue';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
    title?: string;
    description?: string;
    fullscreen?: boolean;
}

const {
    title = 'Enrico Morano',
    description = 'Portfolio di Enrico Morano — sviluppatore full stack specializzato in e-commerce, Vue.js, Astro e infrastrutture VPS.',
    fullscreen = false,
} = Astro.props;
---

<html lang="it">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <meta name="apple-mobile-web-app-title" content="Enrico Morano" />
        <link rel="manifest" href="/site.webmanifest" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<meta name="theme-color" content="#293241" />
        <SEO title={title} description={description} />
        <ViewTransitions prefetch="viewport" />
        <script defer data-domain="enricomorano.it" src="https://plausible.io/js/script.js"></script>
    </head>
    <body class="flex flex-col min-h-screen antialiased select-none">
        <a href="#competenze" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-3 focus:py-1 focus:text-sm focus:text-accent focus:border focus:border-accent focus:rounded-md focus:bg-dark/80 focus:backdrop-blur-sm">
            Vai al contenuto principale
        </a>
        <Cursor client:only="vue" />
        <Nav />
        <main id="main-content" class={`flex-grow pb-20 md:pb-0${fullscreen ? '' : ' pt-12 md:pt-14'}`}>
            <slot />
        </main>
        <Footer client:load />
        <WhatsAppButton />

        <script is:inline>
            document.body.addEventListener("dragstart", (e) => {
                e.preventDefault();
                return false;
            });
        </script>
    </body>
</html>
