---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SEO from '../components/SEO.astro';
import Cursor from '../components/Cursor.vue';
import Footer from '../components/Footer.vue';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CookieNotice from '../components/CookieNotice.astro';

interface Props {
    title?: string;
    description?: string;
    fullscreen?: boolean;
    noFooter?: boolean;
    breadcrumbs?: { name: string; url: string }[];
    type?: 'website' | 'article';
    image?: string;
}

const {
    title = 'Enrico Morano',
    description = 'Portfolio di Enrico Morano - sviluppatore full stack specializzato in e-commerce, Vue.js, Astro e infrastrutture VPS.',
    fullscreen = false,
    noFooter = false,
    breadcrumbs,
    type = 'website',
    image = '/og-image.png',
} = Astro.props;
---

<html lang="it">
    <head>
        <meta charset="utf-8" />
        <script is:inline>
            document.documentElement.classList.add('js');
        </script>
        <link
            rel="icon"
            type="image/png"
            href="/favicon-96x96.png"
            sizes="96x96"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon.svg"
        />
        <link
            rel="shortcut icon"
            href="/favicon.ico"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <meta
            name="apple-mobile-web-app-title"
            content="Enrico Morano"
        />
        <link
            rel="manifest"
            href="/site.webmanifest"
        />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1"
        />
        {
            fullscreen && (
                <link
                    rel="preload"
                    href="/fonts/black-ops-one-latin.woff2"
                    as="font"
                    type="font/woff2"
                    crossorigin
                />
            )
        }
        <meta
            name="theme-color"
            content="#293241"
        />
        <SEO
            title={title}
            description={description}
            type={type}
            image={image}
            breadcrumbs={breadcrumbs}
        />
        <ClientRouter prefetch="viewport" />
        <script>
            let cleanup: (() => void) | undefined;

            function boot() {
                import('../lib/analytics').then(
                    ({ initAnalytics, setupPageTracking }) => {
                        initAnalytics();
                        cleanup?.();
                        cleanup = setupPageTracking();
                    },
                );
            }

            if (typeof requestIdleCallback === 'function') {
                requestIdleCallback(boot);
            } else {
                setTimeout(boot, 2000);
            }

            document.addEventListener('astro:page-load', () => {
                import('../lib/analytics').then(({ setupPageTracking }) => {
                    cleanup?.();
                    cleanup = setupPageTracking();
                });
            });
        </script>
    </head>
    <body class="flex flex-col min-h-screen antialiased select-none">
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-9999 focus:px-3 focus:py-1 focus:text-sm focus:text-accent focus:border focus:border-accent focus:rounded-md focus:bg-dark/80 focus:backdrop-blur-sm"
        >
            Vai al contenuto principale
        </a>
        <Cursor client:idle />
        <Nav />
        <main
            id="main-content"
            class={`flex-grow${noFooter ? '' : ' pb-20 md:pb-0'}${fullscreen ? '' : ' pt-12 md:pt-14'}`}
        >
            <slot />
        </main>
        {!noFooter && <Footer client:idle />}
        <WhatsAppButton />

        <script>
            // Tracking link CENTRALIZZATO: 1 solo delegato href-based (mailto/tel/whatsapp/outbound).
            // Niente data-track da ricordarsi pagina per pagina. Vedi lib/analytics -> setupLinkTracking.
            import('../lib/analytics').then(({ setupLinkTracking }) => setupLinkTracking());
        </script>
        <script>
            function initReveal() {
                const els = Array.from(
                    document.querySelectorAll<HTMLElement>('[data-reveal]'),
                ).filter((el) => !el.classList.contains('is-visible'));
                if (!els.length) return;
                const reduce = window.matchMedia(
                    '(prefers-reduced-motion: reduce)',
                ).matches;
                if (reduce || !('IntersectionObserver' in window)) {
                    els.forEach((el) => el.classList.add('is-visible'));
                    return;
                }
                const io = new IntersectionObserver(
                    (entries, obs) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting) {
                                (e.target as HTMLElement).classList.add('is-visible');
                                obs.unobserve(e.target);
                            }
                        });
                    },
                    { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
                );
                els.forEach((el) => io.observe(el));
            }
            document.addEventListener('astro:page-load', initReveal);
        </script>
        <script is:inline>
            document.body.addEventListener('dragstart', (e) => {
                e.preventDefault();
                return false;
            });
        </script>

        <CookieNotice />
    </body>
</html>
