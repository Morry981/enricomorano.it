---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SEO from '../components/SEO.astro';
import Cursor from '../components/Cursor.vue';
import Footer from '../components/Footer.vue';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Enrico Morano',
    description = 'Portfolio di Enrico Morano — sviluppatore full stack specializzato in e-commerce, Vue.js, Astro e infrastrutture VPS.',
} = Astro.props;
---

<html lang="it">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#293241" />
        <SEO title={title} description={description} />
        <ViewTransitions prefetch="viewport" />
    </head>
    <body class="flex flex-col min-h-screen antialiased select-none">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-accent focus:text-dark focus:rounded-lg focus:font-semibold">
            Vai al contenuto principale
        </a>
        <Cursor client:only="vue" />
        <Nav />
        <main id="main-content" class="flex-grow">
            <slot />
        </main>
        <Footer client:load />

        <script is:inline>
            document.body.addEventListener("dragstart", (e) => {
                e.preventDefault();
                return false;
            });
        </script>
    </body>
</html>
