---
import Layout from '../layouts/Layout.astro';
import SkillsBento from '../components/SkillsBento.vue';
import CtaContact from '../components/CtaContact.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';

const faqs: FaqItem[] = [
    {
        question: 'Quali linguaggi di programmazione conosce Enrico Morano?',
        answer: 'PHP, TypeScript, JavaScript, SQL, Bash. Sul frontend usa Vue.js, Astro e Tailwind CSS. Sul backend PHP con PrestaShop e Node.js.',
    },
    {
        question: 'Enrico Morano e\' specializzato in e-commerce?',
        answer: 'Si. In agenzia grafico pubblicitaria ha creato e seguito decine di e-commerce PrestaShop, lavorando a fianco di grafici e account. Poi ha gestito in autonomia un e-commerce con migliaia di referenze: catalogo, marketplace, ordini, customer care, Ads e SEO tecnica.',
    },
    {
        question: 'Enrico Morano si occupa anche di SEO tecnica?',
        answer: 'Si, Enrico fa audit tecnici, ottimizzazione Core Web Vitals, structured data con Schema.org, configurazione GA4 e GTM con attenzione alla privacy.',
    },
    {
        question: 'Enrico Morano fa formazione per il personale aziendale?',
        answer: 'Si, Enrico ha formato tirocinanti e nuovo personale in un\'agenzia grafico pubblicitaria e poi in azienda. Crea guide operative e affianca le persone nella pratica quotidiana, dal caricamento prodotti alla gestione ordini.',
    },
    {
        question: 'Come sceglie Enrico Morano le tecnologie per un progetto?',
        answer: 'Enrico parte dal problema da risolvere, non dallo strumento. Valuta complessita, budget e obiettivi del cliente, poi sceglie la soluzione piu adatta.',
    },
];
---

<Layout
    title="Competenze: e-commerce, automazione, SEO tecnica » Enrico Morano"
    description="PHP, PrestaShop, Vue.js, automazione processi, SEO tecnica, consulenza. Competenze costruite su progetti veri, non su tutorial."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Competenze', url: '/competenze' }]}
>
    <div class="max-w-6xl mx-auto px-8 py-20">
        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-bold mb-4">
                Competenze tecniche<br>e <span class="text-accent">strategiche</span> per PMI
            </h1>
            <p class="text-secondary text-xl max-w-2xl text-balance">
                Le tecnologie con cui lavoro ogni giorno, nella pratica.
            </p>
        </header>

        <div class="min-h-[1600px] md:min-h-[1200px]">
            <SkillsBento client:only="vue" only="main" />
        </div>

        <CtaContact />

        <div class="min-h-[400px] md:min-h-[300px]">
            <SkillsBento client:only="vue" only="learning" />
        </div>

        <FaqSection faqs={faqs} />
    </div>

    <script>
        function scrollToHash() {
            const hash = window.location.hash;
            if (!hash) return;

            const tryScroll = () => {
                const el = document.querySelector(hash);
                if (el) {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return true;
                }
                return false;
            };

            if (!tryScroll()) {
                const observer = new MutationObserver(() => {
                    if (tryScroll()) observer.disconnect();
                });
                observer.observe(document.body, { childList: true, subtree: true });
                setTimeout(() => observer.disconnect(), 5000);
            }
        }

        document.addEventListener('astro:page-load', scrollToHash);
    </script>
</Layout>
