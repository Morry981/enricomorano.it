---
import Layout from '../layouts/Layout.astro';

// Array di placeholder per simulare molti progetti
const projects = Array.from({ length: 12 }, (_, i) => ({
    title: `Progetto ${i + 1}`,
    description: "Descrizione breve del progetto realizzato con tecnologie moderne.",
    category: i % 2 === 0 ? "Web Design" : "Sviluppo Vue"
}));
---

<Layout title="Progetti | Enrico Morano">
    <main class="max-w-6xl mx-auto px-8 py-20" transition:animate="slide">
        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-bold mb-4">
                I miei <span class="text-accent">Progetti</span>
            </h1>
            <p class="text-secondary text-xl max-w-2xl">
                Una selezione dei miei lavori più recenti, spaziando dal web design allo sviluppo frontend avanzato.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {projects.map((project) => (
                <div class="group p-1 bg-primary/5 border border-primary/20 rounded-2xl hover:border-accent/50 transition-all duration-500 hover:shadow-[0_0_30px_rgba(238,108,77,0.1)]">
                    <div class="bg-dark p-6 rounded-[calc(1rem-4px)] h-full flex flex-col">
                        <span class="text-xs font-bold uppercase tracking-widest text-secondary mb-2">
                            {project.category}
                        </span>
                        <h3 class="text-2xl font-bold mb-3 group-hover:text-accent transition-colors">
                            {project.title}
                        </h3>
                        <p class="text-light/60 mb-6 flex-grow">
                            {project.description}
                        </p>
                        <div class="flex items-center text-accent font-semibold group-hover:translate-x-2 transition-transform cursor-pointer">
                            Scopri di più 
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </div>
                    </div>
                </div>
            ))}
        </div>
        
        <footer class="mt-20 text-center py-10 border-t border-primary/10">
            <p class="text-secondary/50 italic">
                Altri progetti in arrivo...
            </p>
        </footer>
    </main>
</Layout>
