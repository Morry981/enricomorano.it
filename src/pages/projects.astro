---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import ProjectTimeline from '../components/ProjectTimeline.vue';
import CtaContact from '../components/CtaContact.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';
import { projectListSchema } from '../data/schemas';

const faqs: FaqItem[] = [
    {
        question: 'Che tipo di progetti realizza Enrico Morano?',
        answer: 'E-commerce su PrestaShop, applicazioni web e mobile, gestionali interni, automazione processi e infrastrutture server. In agenzia ha seguito la creazione di moltissimi e-commerce dal lato tecnico, supportato da un team competente di grafici e account.',
    },
    {
        question: 'E\' possibile vedere esempi del lavoro di Enrico?',
        answer: 'Nella timeline qui sopra si trova una selezione dei progetti principali. Alcuni lavori sono sotto NDA e non possono essere mostrati pubblicamente.',
    },
    {
        question: 'Enrico Morano sviluppa moduli custom per PrestaShop?',
        answer: 'Si, Enrico ha sviluppato moduli custom per gestire catalogo, ordini, integrazioni marketplace e automazione dei flussi di lavoro su PrestaShop 8+. Tra agenzia e azienda ha lavorato su decine di shop con esigenze diverse.',
    },
    {
        question: 'Quanto dura lo sviluppo di un progetto con Enrico Morano?',
        answer: 'Dipende dalla complessita. Un modulo PrestaShop puo richiedere pochi giorni, un e-commerce completo diverse settimane. Enrico definisce sempre tempi chiari prima di iniziare.',
    },
    {
        question: 'Enrico Morano lavora anche su progetti gia avviati?',
        answer: 'Si, Enrico interviene su progetti esistenti per risolvere bug, aggiungere funzionalita o ottimizzare performance. Analizza prima lo stato attuale e propone un piano di intervento.',
    },
];

const timelineProjects = [...projects]
    .filter((p) => p.date)
    .sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));

const siteUrl = (Astro.site ?? 'https://www.enricomorano.it').toString().replace(/\/$/, '');
const projectsSchema = projectListSchema(siteUrl, projects);
---

<Layout
    title="Progetti"
    description="Progetti di Enrico Morano. E-commerce PrestaShop, applicazioni web e mobile, infrastrutture VPS Apache."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Progetti', url: '/projects' }]}
>
    <div class="py-20" transition:animate="slide">
        <header class="max-w-6xl mx-auto px-8 mb-16">
            <h1 class="text-5xl md:text-6xl font-bold mb-4">
                I miei <span class="text-accent">Progetti</span>
            </h1>
            <p class="text-secondary text-xl max-w-2xl text-balance">
                Una selezione dei lavori a cui ho messo mano di recente.
            </p>
        </header>

        <div class="w-full px-2 md:px-8">
            <ProjectTimeline client:visible projects={timelineProjects} />
        </div>

        <section class="max-w-6xl mx-auto px-8 mt-20">
            <h2 class="text-3xl font-bold mb-8">
                Tutti i <span class="text-accent">Progetti</span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {projects.map((project) => (
                    <article class="group p-1 bg-primary/5 border border-primary/20 rounded-2xl hover:border-accent/50 transition-all duration-500 hover:shadow-[0_0_30px_rgba(238,108,77,0.1)]">
                        <div class="bg-dark p-6 rounded-[calc(1rem-4px)] h-full flex flex-col">
                            <span class="text-xs font-bold uppercase tracking-widest text-secondary mb-2">
                                {project.category}
                            </span>
                            <h3 class="text-2xl font-bold mb-3 group-hover:text-accent transition-colors">
                                {project.title}
                            </h3>
                            <p class="text-light/60 mb-4 flex-grow text-balance">
                                {project.description}
                            </p>
                            <div class="flex flex-wrap gap-2 mb-6">
                                {project.tags.map((tag) => (
                                    <span class="text-xs px-2 py-1 bg-primary/20 text-secondary rounded-full">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            <div class="flex gap-4">
                                {project.url && (
                                    <a
                                        href={project.url}
                                        target="_blank"
                                        rel="noopener noreferrer nofollow"
                                        class="flex items-center text-accent font-semibold group-hover:translate-x-1 transition-transform"
                                        aria-label={`Visita il progetto ${project.title}`}
                                    >
                                        Demo
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                                        </svg>
                                    </a>
                                )}
                                {project.repo && (
                                    <a
                                        href={project.repo}
                                        target="_blank"
                                        rel="noopener noreferrer nofollow"
                                        class="flex items-center text-secondary/70 hover:text-light font-semibold transition-colors"
                                        aria-label={`Repository GitHub di ${project.title}`}
                                    >
                                        GitHub
                                    </a>
                                )}
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <div class="max-w-6xl mx-auto px-8 mt-20 text-center py-10 border-t border-primary/10">
            <p class="text-secondary/50 italic text-balance">
                Il resto è sotto NDA, o non abbastanza fotogenico.
            </p>
        </div>

        <FaqSection faqs={faqs} />

        <div class="max-w-6xl mx-auto px-8">
            <CtaContact />
        </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(projectsSchema)} />
</Layout>
