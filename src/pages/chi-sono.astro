---
import Layout from '../layouts/Layout.astro';
import CtaContact from '../components/CtaContact.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';
import { clientReviews } from '../data/reviews';

// Layout 3+2: prime 3 sopra a tutta larghezza, ultime 2 centrate sotto.
const topReviews = clientReviews.slice(0, 3);
const bottomReviews = clientReviews.slice(3, 5);

// Palette icone: una colorata per ogni card, ciclica.
const iconPalette = ['text-accent', 'text-emerald-400', 'text-sky-400', 'text-fuchsia-400', 'text-amber-400'];

const faqs: FaqItem[] = [
    {
        question: 'Chi e\' Enrico Morano?',
        answer: 'Sviluppatore full stack freelance con quasi dieci anni di esperienza. Ha iniziato in un\'agenzia grafico pubblicitaria dove ha creato decine di e-commerce supportato da un team di grafici, copywriter e account. Poi ha gestito in autonomia un e-commerce con migliaia di referenze. Oggi porta questa esperienza alle PMI come freelancer.',
    },
    {
        question: 'Da quanto tempo lavora Enrico Morano come sviluppatore?',
        answer: 'Enrico ha iniziato con uno stage in un\'agenzia grafico pubblicitaria e da allora ha accumulato quasi dieci anni di esperienza pratica. E\' passato dal caricamento prodotti alla creazione di e-commerce, fino allo sviluppo full stack e alla formazione di tirocinanti e nuovo personale.',
    },
    {
        question: 'Qual e\' l\'esperienza di Enrico Morano con gli e-commerce?',
        answer: 'Enrico ha ricostruito e gestito da zero un e-commerce con migliaia di referenze su PrestaShop: catalogo, marketplace, customer care, automazione, Ads e contabilita.',
    },
    {
        question: 'Enrico Morano lavora da remoto o in presenza?',
        answer: 'Principalmente da remoto su tutta Italia. Per clienti nella zona di Cuneo e provincia Enrico e\' disponibile anche per incontri di persona.',
    },
    {
        question: 'Come si puo contattare Enrico Morano?',
        answer: 'E\' possibile scrivergli via email o su WhatsApp. I contatti si trovano in fondo a ogni pagina del sito. Enrico risponde di solito entro 24 ore.',
    },
];
---

<Layout
    title="Chi è Enrico Morano » Freelance e-commerce e consulenza PMI"
    description="Da uno stage in agenzia alla gestione completa di un e-commerce. 10 anni di esperienza sul campo, oggi al servizio delle PMI come freelance."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Chi Sono', url: '/chi-sono' }]}
>
    <div class="max-w-4xl mx-auto px-8 py-20">
        <h1 class="text-5xl font-bold mb-8"><span class="text-accent">Enrico Morano</span><br>10 anni tra codice, e-commerce e strategia</h1>

        <h2 class="text-3xl font-bold mb-6">Il percorso</h2>
        <div class="prose prose-invert prose-lg text-light/90 space-y-6">
            <p class="text-balance">
                Ho iniziato con uno stage in agenzia, ci sono rimasto anni e ho finito per gestire e-commerce, clienti e tirocinanti. Poi ho ricostruito da zero un e-commerce complesso. Oggi sono freelancer per portare le mie conoscenze a chi ne ha bisogno (oltre a farlo per passione) continuando a supportare chi ho già seguito.
            </p>
            <p class="text-balance">
                In quasi dieci anni ho toccato tutto: dal caricamento prodotti del primo stage alla gestione di un e-commerce con customer care, automazione AI, marketplace, contabilità e formazione del personale.<br>
                I problemi fuori standard sono quelli che mi riescono meglio.
            </p>
        </div>

        <div class="mt-16">
            <h2 class="text-3xl font-bold mb-6">Come posso aiutare la tua azienda</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Sviluppo & E-commerce</h3>
                <p class="text-secondary/80 text-sm text-balance">PrestaShop 8+, PHP 8+, MySQL. Ho gestito un e-commerce dal catalogo al post-vendita, passando per marketplace e customer care.</p>
            </div>
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Infrastructure & DevOps</h3>
                <p class="text-secondary/80 text-sm text-balance">Configurazione e tuning di server VPS Apache, ottimizzazione performance e scalabilità.</p>
            </div>
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Mobile Development</h3>
                <p class="text-secondary/80 text-sm text-balance">Progettazione e sviluppo di applicazioni native e cross-platform per iOS e Android.</p>
            </div>
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Frontend & Design</h3>
                <p class="text-secondary/80 text-sm text-balance">Interfacce moderne con Vue.js, Astro, Tailwind CSS, con focus su UX e design system.</p>
            </div>
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Marketing Tecnico & SEO</h3>
                <p class="text-secondary/80 text-sm text-balance">SEO tecnica, GA4, GTM, mail marketing. Privacy by design e tracking per e-commerce.</p>
            </div>
            <div class="bento-card">
                <h3 class="text-xl font-bold mb-3 text-accent">Project Management</h3>
                <p class="text-secondary/80 text-sm text-balance">Gestione clienti, formazione personale, analisi ROI canali digitali. Ho formato tirocinanti e nuovi assunti in agenzia e in azienda.</p>
            </div>
        </div>

        <section class="mt-16 space-y-6">
            <h2 class="text-3xl font-bold">Cosa dicono i clienti</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {topReviews.map((r, i) => (
                    <article class="bento-card flex flex-col gap-3">
                        <div class="flex items-center gap-3">
                            <svg
                                class={`w-8 h-8 ${iconPalette[i % iconPalette.length]}`}
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
                            </svg>
                            <div aria-label={`Valutazione: ${r.rating} stelle su 5`} class="text-base tracking-wide">⭐⭐⭐⭐⭐</div>
                        </div>
                        <h3 class="text-lg font-bold text-light text-balance">{r.title}</h3>
                        <p class="text-light/80 text-sm text-balance flex-1">{r.body}</p>
                        <footer class="text-secondary text-xs pt-2 border-t border-secondary/10">
                            <span class="font-semibold text-light/90">{r.author}</span>
                        </footer>
                    </article>
                ))}
            </div>

            {bottomReviews.length > 0 && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto">
                    {bottomReviews.map((r, i) => (
                        <article class="bento-card flex flex-col gap-3">
                            <div class="flex items-center gap-3">
                                <svg
                                    class={`w-8 h-8 ${iconPalette[(i + 3) % iconPalette.length]}`}
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
                                </svg>
                                <div aria-label={`Valutazione: ${r.rating} stelle su 5`} class="text-base tracking-wide">⭐⭐⭐⭐⭐</div>
                            </div>
                            <h3 class="text-lg font-bold text-light text-balance">{r.title}</h3>
                            <p class="text-light/80 text-sm text-balance flex-1">{r.body}</p>
                            <footer class="text-secondary text-xs flex items-center justify-between pt-2 border-t border-secondary/10">
                                <span class="font-semibold text-light/90">{r.author}</span>
                                {r.sourceUrl ? (
                                    <a href={r.sourceUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
                                        via {r.sourceLabel}
                                    </a>
                                ) : null}
                            </footer>
                        </article>
                    ))}
                </div>
            )}
        </section>

        <div class="mt-16 space-y-6">
            <h2 class="text-3xl font-bold">Fuori dal codice</h2>
            <div class="text-light/70 text-lg space-y-4">
                <p class="text-balance">
                    Ballo da quando ho sei anni. Liscio da sala, standard, latino agonistico e caraibico.
                    Faccio anche da tutor nella mia scuola di ballo.
                </p>
                <p class="text-balance">
                    Per il resto: film, serie, anime, musica coreana e giapponese.
                    Viaggio appena posso, mostre d'arte e musei compresi.
                    E ovviamente programmo anche nel tempo libero, con utility ed estensioni che mi servono al momento.
                </p>
            </div>
        </div>

        <FaqSection faqs={faqs} />

        <CtaContact />
    </div>
</Layout>
