---
import Layout from '../layouts/Layout.astro';
import SkillsBento from '../components/SkillsBento.vue';
import CtaContact from '../components/CtaContact.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';

const faqs: FaqItem[] = [
    {
        question: 'Quali linguaggi di programmazione conosci?',
        answer: 'PHP, TypeScript, JavaScript, SQL, Bash. Sul frontend uso Vue.js, Astro e Tailwind CSS. Sul backend PHP con PrestaShop e Node.js.',
    },
    {
        question: 'Sei specializzato in e-commerce?',
        answer: 'Sì. In agenzia grafico pubblicitaria ho creato e seguito decine di e-commerce PrestaShop, lavorando a fianco di grafici e account. Poi ho gestito in autonomia un e-commerce con migliaia di referenze: catalogo, marketplace, ordini, customer care, Ads e SEO tecnica.',
    },
    {
        question: 'Ti occupi anche di SEO tecnica?',
        answer: 'Sì, faccio audit tecnici, ottimizzazione Core Web Vitals, structured data con Schema.org, configurazione GA4 e GTM con attenzione alla privacy.',
    },
    {
        question: 'Fai formazione per il personale aziendale?',
        answer: 'Sì, ho formato tirocinanti e nuovo personale in un\'agenzia grafico pubblicitaria e poi in azienda. Creo guide operative e affianco le persone nella pratica quotidiana, dal caricamento prodotti alla gestione ordini.',
    },
    {
        question: 'Come scegli le tecnologie per un progetto?',
        answer: 'Parto dal problema da risolvere, non dallo strumento. Valuto complessità, budget e obiettivi del cliente, poi scelgo la soluzione più adatta.',
    },
];
---

<Layout
    title="Competenze"
    description="Competenze di Enrico Morano. Vue.js, Astro, TypeScript, PHP, PrestaShop, Node.js, SEO tecnica e gestione server VPS."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Competenze', url: '/skills' }]}
>
    <div class="max-w-6xl mx-auto px-8 py-20">
        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-bold mb-4">
                Le mie <span class="text-accent">Competenze</span>
            </h1>
            <p class="text-secondary text-xl max-w-2xl text-balance">
                Le tecnologie con cui lavoro ogni giorno, nella pratica.
            </p>
        </header>

        <SkillsBento client:only="vue" only="main" />

        <CtaContact />

        <SkillsBento client:only="vue" only="learning" />

        <FaqSection faqs={faqs} />
    </div>

    <script>
        function scrollToHash() {
            const hash = window.location.hash;
            if (!hash) return;

            const tryScroll = () => {
                const el = document.querySelector(hash);
                if (el) {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return true;
                }
                return false;
            };

            if (!tryScroll()) {
                const observer = new MutationObserver(() => {
                    if (tryScroll()) observer.disconnect();
                });
                observer.observe(document.body, { childList: true, subtree: true });
                setTimeout(() => observer.disconnect(), 5000);
            }
        }

        document.addEventListener('astro:page-load', scrollToHash);
    </script>
</Layout>
