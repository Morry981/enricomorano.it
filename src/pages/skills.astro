---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Competenze | Enrico Morano">
    <main class="max-w-6xl mx-auto px-8 py-20">
        <h1 class="text-5xl font-bold mb-12">Le mie <span class="text-accent">Competenze</span></h1>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="p-6 bg-dark border border-primary/20 rounded-xl">
                <h3 class="text-xl font-bold text-secondary mb-4">Frontend</h3>
                <ul class="space-y-2 text-light/80">
                    <li>Vue.js / Nuxt</li>
                    <li>Astro</li>
                    <li>Tailwind CSS</li>
                    <li>TypeScript</li>
                </ul>
            </div>
            <!-- Altre categorie -->
        </div>
    </main>
</Layout>
