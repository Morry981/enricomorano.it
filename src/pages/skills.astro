---
import Layout from '../layouts/Layout.astro';
import SkillsBento from '../components/SkillsBento.vue';
---

<Layout
    title="Competenze"
    description="Le competenze tecniche di Enrico Morano: Vue.js, Astro, TypeScript, PHP, PrestaShop, Node.js e molto altro."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Competenze', url: '/skills' }]}
>
    <main class="max-w-6xl mx-auto px-8 py-20">
        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-bold mb-4">
                Le mie <span class="text-accent">Competenze</span>
            </h1>
            <p class="text-secondary text-xl max-w-2xl text-balance">
                Un mix di tecnologie moderne e design creativo per costruire il web del futuro.
            </p>
        </header>

        <SkillsBento client:only="vue" />
    </main>
</Layout>
