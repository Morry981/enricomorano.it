---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
    d.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
    title="Blog"
    description="Guide e debugging story reali su PrestaShop, e-commerce e SEO tecnica."
    breadcrumbs={[
        { name: 'Home', url: '/' },
        { name: 'Blog', url: '/blog' },
    ]}
>
    <div class="max-w-4xl mx-auto px-6 md:px-8 py-16 md:py-24">
        <header class="mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-balance">Blog</h1>
            <p class="mt-4 text-secondary text-lg text-balance">
                Guide e debugging story reali su PrestaShop, e-commerce e SEO tecnica.
            </p>
        </header>

        {
            posts.length === 0 ? (
                <p class="text-secondary">Presto i primi articoli.</p>
            ) : (
                <ul class="space-y-6">
                    {posts.map((post) => (
                        <li class="group overflow-hidden rounded-2xl corner-squircle border border-(--border) bg-(--surface) backdrop-blur-sm transition-all duration-500 hover:border-accent/30">
                            <a href={`/blog/${post.id}`} class="flex flex-col sm:flex-row no-underline">
                                {post.data.cover && (
                                    <img
                                        src={post.data.cover}
                                        alt=""
                                        loading="lazy"
                                        class="w-full sm:w-52 h-44 sm:h-auto sm:self-stretch object-cover shrink-0 border-b sm:border-b-0 sm:border-r border-(--border)"
                                    />
                                )}
                                <div class="p-6 min-w-0">
                                    <h2 class="text-2xl font-semibold text-balance transition-colors group-hover:text-accent">
                                        {post.data.title}
                                    </h2>
                                    <p class="mt-2 text-secondary text-balance">
                                        {post.data.description}
                                    </p>
                                    <p class="mt-3 text-sm text-secondary/70">
                                        {fmt(post.data.pubDate)}
                                        {post.data.tags.length > 0 && (
                                            <span class="ml-1 text-accent/80">
                                                {post.data.tags.map((t) => `#${t}`).join(' ')}
                                            </span>
                                        )}
                                    </p>
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>
            )
        }
    </div>
</Layout>
