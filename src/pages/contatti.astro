---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import AntiSpamEmail from '../components/AntiSpamEmail.vue';

// SSR (niente prerender): legge ?ok / ?error per il fallback senza JS.
const sent = Astro.url.searchParams.get('ok') === '1';
const failed = Astro.url.searchParams.has('error');

const waNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '').replace('+', '');
const waMsg = (text: string) =>
    waNumber ? `https://wa.me/${waNumber}?text=${encodeURIComponent(text)}` : '';
const waUrl = waMsg('Vorrei parlarti di un progetto');
const waCallUrl = waMsg('Vorrei prenotare una call conoscitiva');

// Numero in chiaro formattato per il tasto WhatsApp.
const waRaw = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '').trim();
const waDisplay = /^\+39\d{10}$/.test(waRaw)
    ? '+39 ' + waRaw.slice(3).replace(/(\d{3})(\d{3})(\d{4})/, '$1 $2 $3')
    : waRaw;

// GMB opzionale: mostrato solo se valorizzato in env.
const gmbUrl = (import.meta.env.PUBLIC_GMB_URL ?? '').trim();

// Box percorso -> preselezione del tipo nel form (?tipo=, gestito server-side da ContactForm).
const pathProgetto = `/contatti?tipo=${encodeURIComponent('Nuovo e-commerce o sito vetrina')}#contact-form`;
const pathAiuto = `/contatti?tipo=${encodeURIComponent('Assistenza / problema sullo shop')}#contact-form`;

const channelClass =
    'flex items-center gap-3 w-full px-4 py-3 rounded-lg border border-secondary/30 hover:border-accent transition-colors no-underline';
// La call e la CTA primaria tra i canali: bordo accent già di default.
const callClass =
    'flex items-center gap-3 w-full px-4 py-3 rounded-lg border border-accent bg-accent/5 hover:bg-accent/10 transition-colors no-underline';

const siteUrl = (Astro.site ?? 'https://www.enricomorano.it').toString().replace(/\/$/, '');
const contactSchema = {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contatti - Enrico Morano',
    description:
        'Contatta Enrico Morano per assistenza PrestaShop, sviluppo e-commerce o automazioni. Risposta entro 24 ore.',
    url: `${siteUrl}/contatti`,
};
---

<Layout
    title="Contatti » Enrico Morano, sviluppatore PrestaShop freelance"
    description="Scrivimi per assistenza PrestaShop, sviluppo e-commerce o automazioni su misura. Form, email o WhatsApp: rispondo entro 24 ore, senza preventivi a scatola chiusa."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contatti', url: '/contatti' }]}
>
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-20">
        <header class="max-w-3xl mb-10">
            <h1 class="text-4xl md:text-6xl font-bold leading-[1.08] mb-5 text-balance">
                Parliamo del tuo <span class="text-accent">progetto</span>
            </h1>
            <p class="text-secondary text-xl leading-relaxed text-balance">
                Raccontami cosa ti serve o cosa non funziona: ti rispondo entro 24 ore con un
                parere concreto, senza preventivi a scatola chiusa. Più dettagli mi dai, più la
                prima risposta è utile.
            </p>
        </header>

        {sent && (
            <p class="mb-8 rounded-lg border border-accent/40 bg-accent/10 px-5 py-4 text-light">
                Messaggio inviato. Ti rispondo entro 24 ore.
            </p>
        )}
        {failed && (
            <p class="mb-8 rounded-lg border border-red-500/40 bg-red-500/10 px-5 py-4 text-light">
                Invio non riuscito. Riprova oppure scrivimi direttamente via email o WhatsApp.
            </p>
        )}

        {/* Due percorsi: chiariscono l'intento e preselezionano il tipo nel form */}
        <div class="grid sm:grid-cols-2 gap-5 mb-12">
            <a href={pathProgetto} class="bento-card block group no-underline">
                <h2 class="text-lg font-bold mb-2 group-hover:text-accent transition-colors">
                    Hai un progetto in testa?
                </h2>
                <p class="text-secondary text-sm text-balance">
                    Nuovo e-commerce o migrazione. Dimmi dove vuoi arrivare: ti dico cosa si può
                    fare, tempi e costi, senza giri di parole.
                </p>
            </a>
            <a href={pathAiuto} class="bento-card block group no-underline">
                <h2 class="text-lg font-bold mb-2 group-hover:text-accent transition-colors">
                    Qualcosa non funziona sul tuo shop?
                </h2>
                <p class="text-secondary text-sm text-balance">
                    Errori, lentezze, aggiornamenti andati male, integrazioni rotte. Descrivi il
                    problema: rispondo io, non un ticket automatico.
                </p>
            </a>
        </div>

        <div class="grid lg:grid-cols-[1.3fr_1fr] gap-10 lg:gap-16 items-start">
            <div>
                <ContactForm />
            </div>

            <aside class="space-y-8 lg:pt-2">
                <section>
                    <h2 class="text-lg font-bold mb-4">Canali diretti</h2>
                    <div class="flex flex-col gap-3">
                        <AntiSpamEmail variant="button" label="Scrivimi una mail" subject="Richiesta dal sito - contatti" from="contatti" client:visible />

                        {waUrl && (
                            <a href={waUrl} target="_blank" rel="noopener noreferrer"
                                data-track="whatsapp" class={channelClass}>
                                <svg viewBox="0 0 24 24" fill="currentColor" class="size-5 shrink-0 text-accent">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                                </svg>
                                <span class="flex flex-col text-left">
                                    <span class="text-light font-medium leading-tight">WhatsApp</span>
                                    <span class="text-xs text-secondary/80 leading-tight">{waDisplay}</span>
                                </span>
                            </a>
                        )}

                        {waCallUrl && (
                            <a href={waCallUrl} target="_blank" rel="noopener noreferrer"
                                data-track="whatsapp" class={callClass}>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-5 shrink-0 text-accent">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/>
                                </svg>
                                <span class="flex flex-col text-left">
                                    <span class="text-light font-medium leading-tight">Prenota una call</span>
                                    <span class="text-xs text-secondary/80 leading-tight">20 min su WhatsApp, senza impegno</span>
                                </span>
                            </a>
                        )}

                        {gmbUrl && (
                            <a href={gmbUrl} target="_blank" rel="noopener noreferrer" class={channelClass}>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-5 shrink-0 text-accent">
                                    <path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                                <span class="flex flex-col text-left">
                                    <span class="text-light font-medium leading-tight">Google Business</span>
                                    <span class="text-xs text-secondary/80 leading-tight">recensioni e mappa</span>
                                </span>
                            </a>
                        )}
                    </div>
                    <p class="text-secondary/80 text-sm mt-4">Rispondo di solito entro 24 ore.</p>
                </section>

                <section>
                    <h2 class="text-lg font-bold mb-2">Dove lavoro</h2>
                    <p class="text-secondary text-sm text-balance">
                        Da remoto in tutta Italia. Per la zona di Cuneo e provincia anche di
                        persona.
                    </p>
                </section>
            </aside>
        </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
</Layout>
